# .deploy.env.example — ตัวอย่างค่า environment สำหรับ deploy-lftp.sh
# ❌ ห้าม commit ไฟล์ .deploy.env จริงขึ้น GitHub

FTP_HOST=27.254.41.232
FTP_PORT=2121
FTP_USER=sdak@obec.in
FTP_PASS=YOUR_FTP_PASSWORD_HERE
FTP_PROTOCOL=ftp
FTP_TLS_VERIFY=no
REMOTE_DIR=/
SITE_URL=https://sdak.obec.in
DEPLOY_SECRET=your-webhook-secret
REMOTE_STATE_URL=https://sdak.obec.in/deploy-state.php
BACKUP_URL=https://sdak.obec.in/backup-db.php
MIGRATE_URL=https://sdak.obec.in/migrate.php

# Optional flags
# If you want the script to check remote deployed commit state before upload:
# CHECK_REMOTE_STATE=yes
# To skip remote state validation, set to no
# CHECK_REMOTE_STATE=no

# If your remote path is not the FTP root, set REMOTE_DIR to that path (for example /public_html)
# REMOTE_DIR=/public_html
